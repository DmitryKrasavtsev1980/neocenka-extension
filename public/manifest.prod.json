{
  "manifest_version": 3,
  "name": "Неоценка",
  "version": "1.4.0",
  "description": "Анализ сделок с недвижимостью",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://neocenka.ru/*",
    "https://nominatim.openstreetmap.org/*",
    "https://*.cian.ru/*",
    "https://images.cdn-cian.ru/*",
    "https://*.avito.ru/*",
    "https://*.img.avito.st/*",
    "https://api.z.ai/*",
    "https://unpkg.com/*",
    "https://esm.sh/*",
    "https://*.s3.ru1.storage.beget.cloud/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Неоценка"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/pages/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.cian.ru/*"],
      "js": ["content/cian-parser.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.avito.ru/*"],
      "js": ["content/avito-parser.js"],
      "run_at": "document_idle"
    }
  ]
}
